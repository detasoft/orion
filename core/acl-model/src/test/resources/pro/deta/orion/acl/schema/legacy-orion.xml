<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AccessControl>
    <grants>
        <grant>
            <id>ALL_REPOSITORY</id>
            <info>
                <expression>
                    <key>REPOSITORY</key>
                    <value>*</value>
                </expression>
                <expression>
                    <key>READ</key>
                    <value>true</value>
                </expression>
                <expression>
                    <key>WRITE</key>
                    <value>true</value>
                </expression>
                <expression>
                    <key>CREATE</key>
                    <value>true</value>
                </expression>
                <expression>
                    <key>BRANCH</key>
                    <value>*</value>
                </expression>
            </info>
        </grant>
    </grants>
    <roles>
        <role>
            <id>ROOT</id>
            <grantReferences>
                <grantReference>ALL_REPOSITORY</grantReference>
            </grantReferences>
            <grants/>
        </role>
    </roles>
    <users>
        <user>
            <id>root</id>
            <email>root@orion.pro</email>
            <credentials>
                <credential>
                    <type>ARGON2</type>
                    <value>root-password-hash</value>
                </credential>
            </credentials>
            <roles>
                <role>ROOT</role>
            </roles>
            <grants/>
        </user>
    </users>
</AccessControl>
